# Local web development example.
# Copy to apps/web/.env.development.local for local-only dev overrides.

# Use Vite dev proxy in apps/web/vite.config.ts to avoid browser CORS.
VITE_API_BASE=/api

# Cloudflare Turnstile official test site key, always passes on any hostname.
# Production can omit this variable and use the built-in production site key fallback.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Production normally uses same-origin /api and does not need VITE_API_BASE.
# VITE_API_BASE=/api
