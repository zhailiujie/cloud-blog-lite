{
  "name": "@cloud-blog-lite/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy --config wrangler.production.toml",
    "deploy:production": "wrangler deploy --config wrangler.production.toml",
    "typecheck": "tsc --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply cloud-blog-lite --local",
    "d1:migrate:remote": "wrangler d1 migrations apply cloud-blog-lite --remote --config wrangler.production.toml"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240524.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.94.0"
  }
}
